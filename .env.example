# ─── CreditCheck Dashboard — Environment Variables ───────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control — it is already in .gitignore.
#
# All variables prefixed VITE_ are embedded in the client bundle at build time.
# Do NOT put high-sensitivity secrets (private keys, DB passwords) here.
# Use a server-side secrets manager (AWS Secrets Manager, Vault, etc.) for those.

# ── Authentication (C-01) ─────────────────────────────────────────────────────
# SHA-256 hex hash of the dashboard password.
# Generate: node -e "require('crypto').createHash('sha256').update('yourpassword').digest('hex')|0" | node
# Or online (no secrets): https://emn178.github.io/online-tools/sha256.html
# Leave empty to disable the auth gate (development only).
VITE_AUTH_PASSWORD_HASH=

# ── Storage Encryption Key (C-02) ────────────────────────────────────────────
# Passphrase used to derive the AES-GCM key for encrypting localStorage values.
# Use a long random string (32+ chars). Changing this value invalidates all
# previously stored data (partners, settings, starred leads).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_STORAGE_KEY=change-me-to-a-long-random-string-in-production

# ── Live Data API (H-04) ──────────────────────────────────────────────────────
# Full URL of the live XLSX export endpoint.
# This replaces the hardcoded https://ibancheck.io/api/credit-exports URL.
VITE_API_ENDPOINT=https://ibancheck.io/api/credit-exports

# Bearer token for authenticating requests to VITE_API_ENDPOINT.
# Leave empty if the endpoint does not require authentication (not recommended).
VITE_API_TOKEN=

# ── Excluded Email Domains (M-07) ─────────────────────────────────────────────
# Comma-separated list of email domain suffixes to exclude from lead processing.
# These are treated as internal/test addresses and filtered out during XLSX parsing.
# Example: @clovrlabs.io,@staging.example.com
VITE_EXCLUDED_EMAIL_DOMAINS=@clovrlabs.io

# ── Audit Logging (M-04) ──────────────────────────────────────────────────────
# HTTPS endpoint to POST audit events (lead exports, uploads, partner edits).
# Events contain action name, timestamp, session ID, and sanitised metadata — NO PII.
# Leave empty to queue events in sessionStorage instead of sending to a server.
VITE_AUDIT_ENDPOINT=
