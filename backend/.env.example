# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://creditcheck_user:changeme@localhost:5432/creditcheck_db"

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_64_BYTE_HEX_SECRET"
JWT_EXPIRES_IN="8h"

# ─── App ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Team email whitelist (comma-separated) ─────────────────────────────────
ALLOWED_EMAILS="david@clovrlabs.com,ferran@clovrlabs.com"

# ─── Rate limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─── CORS ───────────────────────────────────────────────────────────────────
# Production (Vercel frontend):
CORS_ORIGIN="https://credit-check-dashboard.vercel.app"
# Development:
# CORS_ORIGIN="http://localhost:5173"
